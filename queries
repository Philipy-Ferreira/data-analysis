**Marketplace concentration**

  **Query**

    CREATE OR REPLACE VIEW `olist-490117.1.revenue_per_seller` AS
    SELECT
      oi.seller_id,
      ROUND (SUM(oi.price),2) AS revenue
    FROM `olist-490117.1.order_items` oi
    JOIN `olist-490117.1.orders` o
      ON o.order_id = oi.order_id
    WHERE
      DATE_TRUNC(DATE(o.order_purchase_timestamp), MONTH)
          BETWEEN DATE '2017-08-01' AND DATE '2018-08-31'
      AND o.order_status = 'delivered'
    GROUP BY seller_id
    ORDER BY revenue DESC;
    
    
    CREATE OR REPLACE VIEW `olist-490117.1.seller_market_share` AS
    SELECT
      rs.seller_id,
      (rs.revenue/t.total_revenue) AS market_share
    FROM `olist-490117.1.revenue_per_seller` rs
    CROSS JOIN (
      SELECT SUM(revenue) as total_revenue
      FROM `olist-490117.1.revenue_per_seller`
    ) t;
    
    SELECT 
      SUM(POWER(market_share,2))*10000 AS hhi
    FROM
      `olist-490117.1.seller_market_share`


    CREATE OR REPLACE VIEW `olist-490117.1.revenue_per_state` AS
